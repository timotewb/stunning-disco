// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model TeamMember {
  id            String          @id @default(uuid())
  name          String
  role          String
  seniority     String
  tags          String          @default("[]")
  notes         String          @default("")
  isLeaving     Boolean         @default(false)
  createdAt     DateTime        @default(now())
  matrixEntries MatrixEntry[]
  allocations   Allocation[]
  workRequests  WorkRequest[]   @relation("RequestAssignee")
  primarySME    SMEAssignment[] @relation("PrimarySME")
  backupSME     SMEAssignment[] @relation("BackupSME")
}

model Dimension {
  id          String          @id @default(uuid())
  name        String
  type        String          @default("skills")
  description String          @default("")
  nodes       DimensionNode[]
}

model DimensionNode {
  id             String          @id @default(uuid())
  dimensionId    String
  parentId       String?
  name           String
  orderIndex     Int             @default(0)
  dimension      Dimension       @relation(fields: [dimensionId], references: [id], onDelete: Cascade)
  parent         DimensionNode?  @relation("NodeChildren", fields: [parentId], references: [id])
  children       DimensionNode[] @relation("NodeChildren")
  matrixEntries  MatrixEntry[]
  smeAssignments SMEAssignment[]
}

model Snapshot {
  id             String          @id @default(uuid())
  timestamp      DateTime
  matrixEntries  MatrixEntry[]
  smeAssignments SMEAssignment[]
}

model MatrixEntry {
  id              String        @id @default(uuid())
  teamMemberId    String
  dimensionNodeId String
  snapshotId      String
  value           Int           @default(0)
  teamMember      TeamMember    @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  dimensionNode   DimensionNode @relation(fields: [dimensionNodeId], references: [id], onDelete: Cascade)
  snapshot        Snapshot      @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([teamMemberId, dimensionNodeId, snapshotId])
}

model Allocation {
  id           String     @id @default(uuid())
  teamMemberId String
  projectName  String
  type         String     @default("project")
  startDate    DateTime
  endDate      DateTime
  notes        String     @default("")
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
}

model AllocationTypeConfig {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String   @default("gray")
  createdAt DateTime @default(now())
}

model WorkRequest {
  id                  String      @id @default(uuid())
  title               String
  description         String?
  source              String      @default("planning")
  sourceDetail        String?
  type                String      @default("other")
  priority            String      @default("medium")
  status              String      @default("new")
  isDraft             Boolean     @default(false)
  effort              String?
  dateRaised          DateTime    @default(now())
  dateResolved        DateTime?
  assigneeId          String?
  assignee            TeamMember? @relation("RequestAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  // Allocation section — populated when the request is scheduled on the Timeline
  isAllocated         Boolean     @default(false)
  allocationType      String?
  allocationStartDate DateTime?
  allocationEndDate   DateTime?
  allocationNotes     String?
  // Metadata
  noteRef             String?
  tags                String      @default("[]")
  externalRef         String?
  dimensionNodeIds    String      @default("[]")
  notes               String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([isAllocated, allocationStartDate, allocationEndDate])
  @@index([assigneeId, isAllocated])
}

model SeniorityConfig {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String   @default("gray")
  createdAt DateTime @default(now())
}

model SMEAssignment {
  id              String        @id @default(uuid())
  dimensionNodeId String
  primaryMemberId String
  backupMemberId  String?
  snapshotId      String
  dimensionNode   DimensionNode @relation(fields: [dimensionNodeId], references: [id], onDelete: Cascade)
  primaryMember   TeamMember    @relation("PrimarySME", fields: [primaryMemberId], references: [id], onDelete: Cascade)
  backupMember    TeamMember?   @relation("BackupSME", fields: [backupMemberId], references: [id])
  snapshot        Snapshot      @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([dimensionNodeId, snapshotId])
}
